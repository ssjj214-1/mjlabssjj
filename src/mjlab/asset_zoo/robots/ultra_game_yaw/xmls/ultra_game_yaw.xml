<mujoco model="ultra_game_yaw">
  <compiler angle="radian" meshdir="../assets" eulerseq="zyx" autolimits="true"/>

  <default>
    <default class="ultra">
      <default class="visual">
        <geom group="2" type="mesh" density="0" material="body" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom group="3" rgba=".2 .6 .2 .3" type="cylinder" contype="1" conaffinity="1" condim="1"/>
        <default class="foot">
          <!-- Sole approximated by thin capsules (matches the ultra_run_lab
               source mjcf). Capsule-vs-heightfield is an analytic, stable
               collision; the previous single ``type="mesh"`` foot forced
               mesh-vs-hfield through CCD/EPA, which fails to converge on rough
               terrain ("EPA horizon isn't large enough") and produces garbage
               contact forces -> NaN. -->
          <geom type="capsule" size="0.01" condim="3" friction="0.6 0.5 0.005" priority="1"/>
        </default>
      </default>
      <site group="5" rgba="1 0 0 1"/>
    </default>
  </default>

  <asset>
